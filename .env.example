# サーバー設定
BIND_ADDR=0.0.0.0:3000
APP_URL=http://localhost:3000

# データベース (ローカル開発はデフォルトのまま可)
DATABASE_URL=sqlite:./bottles.db?mode=rwc

# WebAuthn (APP_URL のホスト部分と一致させる)
RP_ID=localhost

# メール送信 (未設定時はターミナルにリンクを表示)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=noreply@example.com

# AI画像解析 (未設定時はエンドポイント自体がエラーを返す)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 管理者認証 (未設定時は POST /v1/shops が認証なしで使える)
ADMIN_SECRET=your-random-secret

# CORS (未設定時は全オリジン許可)
CORS_ORIGIN=http://localhost:5173

# 期限通知の実行時刻 (UTC, デフォルト=13 → JST 22時)
NOTIFY_HOUR=3

# デモショップの初期PIN (未設定時は 1234)
DEMO_PIN=1234
